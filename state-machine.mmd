%% Solar Tracker — Auto Tracking State Machine
%% Paste into https://mermaid.live/

stateDiagram-v2
    [*] --> BOOT: Power On
    BOOT --> NORMAL: setup()
    
    NORMAL --> PULSE: diff >= 200
    PULSE --> NORMAL: 200ms timer
    
    NORMAL --> STUCK_LEFT: leftLimit and wantLeft 5x
    NORMAL --> STUCK_RIGHT: rightLimit and wantRight 5x
    
    STUCK_LEFT --> WRAP_RIGHT
    STUCK_RIGHT --> WRAP_LEFT
    
    WRAP_LEFT --> ESCAPE_LEFT: hit leftLimit
    WRAP_RIGHT --> ESCAPE_RIGHT: hit rightLimit
    
    ESCAPE_LEFT --> NORMAL: 5 pulses done
    ESCAPE_RIGHT --> NORMAL: 5 pulses done
    
    NORMAL --> MANUAL: Menu to Manual
    MANUAL --> NORMAL: Menu to Auto
    
    NORMAL --> SLEEP: Menu to Sleep
    MANUAL --> SLEEP: Menu to Sleep
    SLEEP --> BOOT: Wake timer or button
